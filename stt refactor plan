# inference/loader.py
"""Lazy model singleton. The model is loaded once on first transcription request.
Never import at module scope in app.py — that causes load on container start."""

import threading
import torch
from transformers import Wav2Vec2BertForCTC, Wav2Vec2BertProcessor
from config import MODEL_NAME

_lock = threading.Lock()
_model = None
_processor = None


def get_model_and_processor() -> tuple[Wav2Vec2BertForCTC, Wav2Vec2BertProcessor]:
    """Return the singleton (model, processor) pair, loading on first call."""
    global _model, _processor
    if _model is None:
        with _lock:
            # Double-check after acquiring lock — another thread may have loaded
            if _model is None:
                device = "cuda" if torch.cuda.is_available() else "cpu"
                _processor = Wav2Vec2BertProcessor.from_pretrained(MODEL_NAME)
                _model = Wav2Vec2BertForCTC.from_pretrained(MODEL_NAME).to(device)
                _model.eval()
    return _model, _processor
```

