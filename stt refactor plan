# inference/preprocess.py
"""Audio loading, normalisation, and metadata extraction."""

import os
import numpy as np
import soundfile as sf
import torchaudio
import torchaudio.transforms as T
from pydub import AudioSegment, silence as pydub_silence
from config import TARGET_SAMPLE_RATE, SILENCE_THRESH_DB


def get_audio_duration_secs(path: str) -> float:
    """Return the duration of an audio file in seconds using metadata only.
    This is the admission-control signal — never use file size for this."""
    if not os.path.exists(path):
        raise FileNotFoundError(f"Audio file not found: {path}")
    info = torchaudio.info(path)
    return info.num_frames / info.sample_rate


def load_and_normalise(path: str) -> tuple[np.ndarray, int]:
    """Load audio, convert to mono, resample to TARGET_SAMPLE_RATE.
    Returns a float32 numpy array normalised to [-1, 1] and the sample rate."""
    if not os.path.exists(path):
        raise FileNotFoundError(f"Audio file not found: {path}")
    waveform, sr = torchaudio.load(path)

    # Downmix to mono by averaging channels
    if waveform.shape[0] > 1:
        waveform = waveform.mean(dim=0, keepdim=True)

    # Resample if needed
    if sr != TARGET_SAMPLE_RATE:
        resampler = T.Resample(orig_freq=sr, new_freq=TARGET_SAMPLE_RATE)
        waveform = resampler(waveform)

    array = waveform.squeeze().numpy().astype(np.float32)

    # Peak-normalise to prevent clipping artefacts
    peak = np.abs(array).max()
    if peak > 0:
        array = array / peak * 0.95

    return array, TARGET_SAMPLE_RATE


def trim_silence(path: str, out_path: str) -> str:
    """Strip leading and trailing silence below SILENCE_THRESH_DB.
    Writes result to out_path and returns out_path."""
    audio = AudioSegment.from_file(path)
    trimmed = pydub_silence.detect_leading_silence(audio, silence_threshold=SILENCE_THRESH_DB)
    audio = audio[trimmed:]
    reversed_audio = audio.reverse()
    trimmed_end = pydub_silence.detect_leading_silence(
        reversed_audio, silence_threshold=SILENCE_THRESH_DB
    )
    audio = reversed_audio[trimmed_end:].reverse()
    audio.export(out_path, format="wav")
    return out_path
```

