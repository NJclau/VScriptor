# scheduler/admission.py
"""Duration-based weighted slot admission controller.

Short jobs (≤ SHORT_JOB_THRESHOLD_SECS) get a dedicated priority slot so
they are never blocked by a long job occupying both primary slots.
Long jobs compete for MAX_PRIMARY_SLOTS slots.
"""

import asyncio
from enum import Enum
from config import MAX_PRIMARY_SLOTS, SHORT_JOB_THRESHOLD_SECS, MAX_AUDIO_DURATION_SECS


class SlotType(str, Enum):
    SHORT = "short"
    PRIMARY = "primary"


class AdmissionController:
    def __init__(self):
        # Primary semaphore: gates long jobs
        self._primary = asyncio.Semaphore(MAX_PRIMARY_SLOTS)
        # Short-job semaphore: one dedicated slot for quick jobs
        self._short = asyncio.Semaphore(1)

    async def acquire(self, duration_secs: float) -> SlotType:
        """Acquire the appropriate slot based on audio duration.
        Raises ValueError if duration exceeds the hard cap."""
        if duration_secs > MAX_AUDIO_DURATION_SECS:
            raise ValueError(
                f"Audio duration {duration_secs:.1f}s exceeds maximum "
                f"{MAX_AUDIO_DURATION_SECS}s. Please trim your file."
            )
        if duration_secs <= SHORT_JOB_THRESHOLD_SECS:
            await self._short.acquire()
            return SlotType.SHORT
        else:
            await self._primary.acquire()
            return SlotType.PRIMARY

    def release(self, slot: SlotType) -> None:
        if slot == SlotType.SHORT:
            self._short.release()
        else:
            self._primary.release()
```

