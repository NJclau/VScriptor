# state/cache.py
"""
Volatile in-memory read model. This cache is derived from the dataset repo
and is NEVER the source of truth. It is rebuilt from job_store on startup
and updated after each state transition write. If the Space restarts, the
cache is empty until seeded from the dataset repo again.

The UI polls this cache every CACHE_POLL_INTERVAL_SECS seconds — it NEVER
polls the Hub API directly. This prevents self-inflicted 429 rate limits.
"""

import threading
from typing import Optional

_lock = threading.Lock()
_cache: dict[str, dict] = {}   # job_id -> job record


def seed_from_store(jobs: dict) -> None:
    """Populate the cache at startup from the dataset repo. Call once."""
    with _lock:
        _cache.clear()
        _cache.update(jobs)


def put(job_id: str, record: dict) -> None:
    """Write a job record to the cache after a successful Hub write."""
    with _lock:
        _cache[job_id] = record


def get(job_id: str) -> Optional[dict]:
    """Read a single job record. Returns None if not found."""
    with _lock:
        return _cache.get(job_id)


def get_system_status() -> dict:
    """Return a lightweight summary for the UI status indicator."""
    with _lock:
        active = sum(1 for j in _cache.values() if j["status"] == "processing")
        queued = sum(1 for j in _cache.values() if j["status"] == "queued")
    return {
        "active_jobs": active,
        "queued_jobs": queued,
        "load_level": "low" if active == 0 else "medium" if active < 2 else "high",
    }
```

