# inference/postprocess.py
"""Stitch ordered chunk transcripts into a single clean string."""

import re


def stitch_chunks(transcripts: list[str]) -> str:
    """Join chunk transcripts with a space and clean up whitespace artefacts.
    Duplicate words at chunk boundaries are not removed automatically because
    the overlap is acoustic (signal level), not textual. Post-editors handle
    any residual boundary repetitions in the Gradio textbox."""
    joined = " ".join(t.strip() for t in transcripts if t.strip())
    # Collapse multiple spaces introduced by empty chunks
    cleaned = re.sub(r" {2,}", " ", joined)
    return cleaned.strip()
```

