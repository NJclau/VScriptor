# inference/decoder.py
"""CTC greedy decode from logits to text. Stateless — no model reference held here."""

import torch
from transformers import Wav2Vec2BertProcessor


def decode_logits(logits: torch.Tensor, processor: Wav2Vec2BertProcessor) -> str:
    """Greedy decode: argmax over vocab dimension, then convert token IDs to text.
    Returns a single decoded string for the first item in the batch."""
    predicted_ids = torch.argmax(logits, dim=-1)
    transcription = processor.batch_decode(predicted_ids)
    return transcription[0] if transcription else ""
```

