# inference/chunker.py
"""Sliding window chunker with overlap. Each chunk is written to a temp wav file."""

import os
import numpy as np
import soundfile as sf
from inference.preprocess import load_and_normalise
from config import CHUNK_DURATION_MS, OVERLAP_DURATION_MS, TARGET_SAMPLE_RATE


def chunk_audio(audio_path: str, output_dir: str) -> list[str]:
    """Split audio into overlapping windows.

    Overlap prevents word boundary clipping: the last OVERLAP_DURATION_MS of
    each chunk is repeated at the start of the next. postprocess.py removes
    the duplicate text during stitching.

    Returns a list of file paths to the chunk wav files, in order.
    """
    array, sr = load_and_normalise(audio_path)

    chunk_samples = int((CHUNK_DURATION_MS / 1000) * sr)
    overlap_samples = int((OVERLAP_DURATION_MS / 1000) * sr)
    step = chunk_samples - overlap_samples

    os.makedirs(output_dir, exist_ok=True)
    chunk_paths = []

    start = 0
    idx = 0
    while start < len(array):
        end = min(start + chunk_samples, len(array))
        chunk = array[start:end]
        chunk_path = os.path.join(output_dir, f"chunk_{idx:04d}.wav")
        sf.write(chunk_path, chunk, sr)
        chunk_paths.append(chunk_path)
        start += step
        idx += 1

    return chunk_paths
```

