# state/job_store.py
"""
Authoritative durable state for all transcription jobs.

The Space is a stateless execution surface. This module is the only place
that reads from and writes to the HF Dataset repo. The in-memory cache in
cache.py is a volatile read model derived from this store — it is NEVER
the source of truth.

Write policy: writes happen only on state transitions (create, chunk complete,
job complete, job fail). UI polling reads from cache.py, not here.
"""

import json
import time
import threading
from dataclasses import dataclass, asdict, field
from typing import Optional
from huggingface_hub import HfApi, hf_hub_download, upload_file
from config import (
    HF_DATASET_REPO, JOB_STATE_FILE,
    BACKOFF_BASE_SECS, BACKOFF_MAX_SECS, BACKOFF_MULTIPLIER
)

_write_lock = threading.Lock()


class JobStatus:
    QUEUED = "queued"
    PROCESSING = "processing"
    COMPLETE = "complete"
    FAILED = "failed"


def _pull_from_hub() -> dict:
    """Download the current jobs JSON from the dataset repo.
    Returns an empty dict if the file does not exist yet."""
    try:
        path = hf_hub_download(
            repo_id=HF_DATASET_REPO,
            filename=JOB_STATE_FILE,
            repo_type="dataset",
            force_download=True,   # Always fetch fresh — never trust local cache
        )
        with open(path, "r") as f:
            return json.load(f)
    except Exception:
        return {}


def _push_to_hub(jobs: dict) -> None:
    """Write the full jobs dict to the dataset repo with exponential backoff on 429."""
    import tempfile, os
    with tempfile.NamedTemporaryFile(mode="w", suffix=".json", delete=False) as tmp:
        json.dump(jobs, tmp, indent=2)
        tmp_path = tmp.name

    delay = BACKOFF_BASE_SECS
    while True:
        try:
            upload_file(
                path_or_fileobj=tmp_path,
                path_in_repo=JOB_STATE_FILE,
                repo_id=HF_DATASET_REPO,
                repo_type="dataset",
            )
            break
        except Exception as e:
            if "429" in str(e) or "rate limit" in str(e).lower():
                time.sleep(min(delay, BACKOFF_MAX_SECS))
                delay *= BACKOFF_MULTIPLIER
            else:
                raise
        finally:
            os.unlink(tmp_path)


def create_job(
    job_id: str, audio_path: str, duration_secs: float, total_chunks: int = 0
) -> dict:
    with _write_lock:
        jobs = _pull_from_hub()
        record = {
            "job_id": job_id,
            "status": JobStatus.QUEUED,
            "audio_path": audio_path,
            "duration_secs": duration_secs,
            "total_chunks": total_chunks,
            "chunks_done": 0,
            "transcripts": [],
            "error": None,
        }
        jobs[job_id] = record
        _push_to_hub(jobs)
    return record


def update_job_chunk(job_id: str, chunk_index: int, transcript: str) -> dict:
    with _write_lock:
        jobs = _pull_from_hub()
        record = jobs[job_id]
        record["status"] = JobStatus.PROCESSING
        # Pad transcript list to accommodate out-of-order completion
        while len(record["transcripts"]) <= chunk_index:
            record["transcripts"].append("")
        record["transcripts"][chunk_index] = transcript
        record["chunks_done"] += 1
        jobs[job_id] = record
        _push_to_hub(jobs)
    return record


def complete_job(job_id: str, final_transcript: str) -> dict:
    with _write_lock:
        jobs = _pull_from_hub()
        jobs[job_id]["status"] = JobStatus.COMPLETE
        jobs[job_id]["final_transcript"] = final_transcript
        _push_to_hub(jobs)
    return jobs[job_id]


def fail_job(job_id: str, reason: str) -> dict:
    with _write_lock:
        jobs = _pull_from_hub()
        jobs[job_id]["status"] = JobStatus.FAILED
        jobs[job_id]["error"] = reason
        _push_to_hub(jobs)
    return jobs[job_id]


def load_all_jobs() -> dict:
    """Called at Space startup to recover in-progress and queued jobs."""
    return _pull_from_hub()
```

